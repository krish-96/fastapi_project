# ── Database ───────────────────────────────────────────────────────────────────
# Option A: provide full URL
DB_URL=mysql+aiomysql://db_user:db_password@db_host_ip:db_port/db_name

# Option B: provide individual components (used when DB_URL is absent)

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=db_name

# Connection pool
DB_POOL_SIZE=20
MAX_OVERFLOW_SIZE=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE_TIME=1800   # 30 min — prevents MySQL wait_timeout stale connections
POOL_PRE_PING=true          # SELECT 1 before each use — catches corrupted connections

# ── App ────────────────────────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=9000

# Dev
APP_DEBUG=true
APP_WORKERS=1

# Prod (uncomment below, comment above)
# APP_DEBUG=false
# APP_WORKERS=4              # I/O-bound: 2x physical cores (8 cores → 4 workers)
                             # 4 × (20 + 20) = 160 connections < MySQL 300 max

# ── Queue lifecycle ────────────────────────────────────────────────────────────
CREATE_QUEUE_IF_DELETED=true  # true  = app owns queue, recreate on deletion
                               # false = infra owns queue, alert only

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG   # dev: DEBUG | prod: INFO
ROTATING_FILE_MAX_BYTES=3145728  # 1024 * 1024 * 3 = 3 MB
ROTATING_FILE_BACKUP_COUNT=5

# ── RabbitMQ health checker ────────────────────────────────────────────────────
# poll = use shared channel passive probe (fast, zero new connections)
# sleep = wait RMQ_HEALTH_INITIAL_DELAY_SECS before first probe
RMQ_INITIAL_HEALTH_CHECK_TYPE=poll

# ── RabbitMQ ───────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/   # no quotes needed
RMQ_QUEUE=task_queue
RMQ_EXCHANGE=app_exchange
RMQ_ROUTING_KEY=#             # # = all topics | user.* = partial | user.created = exact
RMQ_DLX=dlx                  # dead-letter exchange — receives nack(requeue=False) messages
RMQ_PREFETCH_COUNT=10

# ── Concurrency ────────────────────────────────────────────────────────────────
# Rule: RMQ_MAX_CONCURRENT_TASKS >= RMQ_PREFETCH_COUNT
# prefetch_count   → RabbitMQ delivers at most N unacked messages (broker-side gate)
# max_concurrent   → app processes at most N messages at once (app-side semaphore)
RMQ_MAX_CONCURRENT_TASKS=50

# ── Shutdown ───────────────────────────────────────────────────────────────────
RMQ_DRAIN_TIMEOUT_SECS=30.0   # wait up to 30s for in-flight messages on shutdown

# ── Health checker ─────────────────────────────────────────────────────────────
RMQ_HEALTH_INTERVAL_SECS=5.0        # probe broker every N seconds
RMQ_PROBE_TIMEOUT_SECS=3.0          # TCP connect timeout for new-connection fallback
RMQ_HEALTH_INITIAL_DELAY_SECS=1.0   # short delay before first probe (consumer startup)
RMQ_MAX_RETRIES=3                    # max retries in rmq_setup before giving up