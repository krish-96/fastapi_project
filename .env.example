# DB configs

# Directly URL, if the below values are not provided
DB_URL=mysql+aiomysql://db_user:db_password@db_host_ip:db_port/db_name

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=validator_db
DB_POOL_SIZE=20

# APP configs
APP_HOST=127.0.0.1
APP_PORT=9000
APP_DEBUG=true
APP_WORKERS=1

# To decide whether to create a missing queue
CREATE_QUEUE_IF_DELETED=true

# Logging Configs
# To play ith the behaviour
#LOG_LEVEL=''
LOG_LEVEL=INFO


# RabbitMQ Controls

RABBITMQ_URL="amqp://guest:guest@localhost:5672/"
RMQ_QUEUE=task_queue
RMQ_EXCHANGE=app_exchange
RMQ_ROUTING_KEY="#"  # match all topics
RMQ_DLX="dlx"  # dead-letter exchange
RMQ_PREFETCH_COUNT=10

# ── Concurrency control ────────────────────
# Rule: RMQ_MAX_CONCURRENT_TASKS >= RMQ_PREFETCH_COUNT
# prefetch_count  → broker delivers at most N unacked messages
# max_concurrent  → app processes at most N messages at once (semaphore)
RMQ_MAX_CONCURRENT_TASKS=50

# ── Shutdown ───────────────────────────────
# wait up to N secs for tasks on shutdown
RMQ_DRAIN_TIMEOUT_SECS=30.0

# ── Health checker ─────────────────────────
# probe every N seconds
RMQ_HEALTH_INTERVAL_SECS=2.0
# TCP connect timeout
RMQ_PROBE_TIMEOUT_SECS=3.0
RMQ_HEALTH_INITIAL_DELAY_SECS=5.0
RMQ_MAX_RETRIES=3
